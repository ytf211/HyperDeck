[
  {
    "category_key": "settings_category_animation",
    "category": "动画相关",
    "items": [
      {
        "title_key": "settings_item_window_animation_scale_title",
        "title": "窗口动画缩放",
        "description_key": "settings_item_window_animation_scale_description",
        "description": "控制窗口动画时长倍数",
        "type": "slider",
        "command": "settings put global window_animation_scale {value}",
        "check_command": "settings get global window_animation_scale",
        "min": 0,
        "max": 2,
        "step": 0.25
      },
      {
        "title_key": "settings_item_transition_animation_scale_title",
        "title": "过渡动画缩放",
        "description_key": "settings_item_transition_animation_scale_description",
        "description": "控制过渡动画时长倍数",
        "type": "slider",
        "command": "settings put global transition_animation_scale {value}",
        "check_command": "settings get global transition_animation_scale",
        "min": 0,
        "max": 2,
        "step": 0.25
      },
      {
        "title_key": "settings_item_animator_duration_scale_title",
        "title": "动画程序时长缩放",
        "description_key": "settings_item_animator_duration_scale_description",
        "description": "控制动画程序时长倍数",
        "type": "slider",
        "command": "settings put global animator_duration_scale {value}",
        "check_command": "settings get global animator_duration_scale",
        "min": 0,
        "max": 2,
        "step": 0.25
      }
    ]
  },
  {
    "category_key": "settings_category_display",
    "category": "显示",
    "items": [
      {
        "title_key": "settings_item_screen_brightness_title",
        "title": "屏幕亮度",
        "description_key": "settings_item_screen_brightness_description",
        "description": "手动设置屏幕亮度 (0-255)",
        "type": "slider",
        "command": "settings put system screen_brightness {value}",
        "check_command": "settings get system screen_brightness",
        "min": 0,
        "max": 255,
        "step": 1
      },
      {
        "title_key": "settings_item_screen_timeout_title",
        "title": "屏幕超时",
        "description_key": "settings_item_screen_timeout_description",
        "description": "自动息屏时间 (毫秒)",
        "type": "input",
        "command": "settings put system screen_off_timeout {value}",
        "check_command": "settings get system screen_off_timeout"
      }
    ]
  },
  {
    "category_key": "settings_category_developer",
    "category": "开发者选项",
    "items": [
      {
        "title_key": "settings_item_usb_debug_title",
        "title": "USB 调试",
        "description_key": "settings_item_usb_debug_description",
        "description": "启用/禁用 USB 调试",
        "type": "toggle",
        "command_on": "settings put global adb_enabled 1",
        "command_off": "settings put global adb_enabled 0",
        "check_command": "settings get global adb_enabled"
      },
      {
        "title_key": "settings_item_stay_awake_title",
        "title": "保持唤醒",
        "description_key": "settings_item_stay_awake_description",
        "description": "充电时保持屏幕常亮",
        "type": "toggle",
        "command_on": "settings put global stay_on_while_plugged_in 3",
        "command_off": "settings put global stay_on_while_plugged_in 0",
        "check_command": "settings get global stay_on_while_plugged_in"
      },
      {
        "title_key": "settings_item_app_preload_title",
        "title": "应用预加载开关",
        "description_key": "settings_item_app_preload_description",
        "description": "控制 touch_prestart_opt_config 的应用预加载策略",
        "type": "toggle",
        "command_on": "settings put system touch_prestart_opt_config \"{featureDisable:false,bgExceptionInterceptDisable:false,touchDownPreStartBlackList:[com.android.camera]}\"",
        "command_off": "settings put system touch_prestart_opt_config \"{featureDisable:false,bgExceptionInterceptDisable:false,touchDownPreStartBlackList:[disable_all_package]}\""
      }
    ]
  }
]
